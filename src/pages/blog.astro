---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/nav.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getPostSlug = (id: string) => id.replace(/\.md$/, "");
---

<Layout title="Blog">
  <Nav />

  <section class="section-container min-h-[80vh] pt-28 md:pt-36">
    <div class="container mx-auto">
      <div class="mb-14">
        <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext mb-4 flex items-center gap-4">
          <span class="text-accent">/</span> Blog
        </h1>
        <p class="text-subtext font-body text-base max-w-2xl leading-relaxed">
          Notes on my projects and probably some writeups.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <article class="group rounded-2xl bg-accent/5 border border-accent/10 hover:border-accent/40 transition-all duration-300 p-6">
            <div class="flex items-center gap-3 text-subtext text-xs mb-4">
              <Icon name="mdi:calendar-outline" class="w-4 h-4 text-accent" />
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>

            <h2 class="text-2xl font-heading font-bold text-maintext mb-3 group-hover:text-accent transition-colors">
              <a href={`/blog/${getPostSlug(post.id)}/`}>{post.data.title}</a>
            </h2>

            <p class="text-subtext text-sm leading-relaxed mb-5">
              {post.data.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-md text-[10px] px-3 py-1 bg-accent/5 border border-accent/10 text-accent/80">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
